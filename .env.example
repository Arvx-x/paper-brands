# Models are addressed as `provider:model`. Two providers are built in, both
# via OpenAI-compatible endpoints: `openai` and `google` (Gemini).

# OpenAI (or any OpenAI-compatible gateway like Bifrost) — strategy / council
PB_BASE_URL=https://api.openai.com/v1
PB_API_KEY=sk-replace-me

# Google AI Studio — fast/cheap high-volume simulation arena
PB_GOOGLE_API_KEY=replace-me
# PB_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Routing
PB_DEFAULT_PROVIDER=openai
PB_MODEL=openai:gpt-4o-mini
PB_SIM_MODEL=google:gemini-2.5-flash

# Concurrency for arena simulations
PB_CONCURRENCY=6

# Creative Factory — Gemini image generation (Interactions API) + multimodal jury.
# Image gen runs on PB_GOOGLE_API_KEY (same key as Gemini search).
PB_IMAGE_MODEL=gemini-3.1-flash-image       # cheap drafts / optimizer iterations
PB_IMAGE_MODEL_PRO=gemini-3-pro-image       # final hero renders (aka nano-banana-pro)
PB_VISION_MODEL=gemini-2.5-flash            # multimodal jury (OpenAI-compat vision)
# PB_GEMINI_NATIVE_URL=https://generativelanguage.googleapis.com/v1beta

# Harvesting uses OpenAI native web search by default (requires PB_API_KEY).
# PB_SEARCH_MODEL=openai:gpt-4o-mini-search-preview

# Optional fallback search APIs (only used if OpenAI search is unavailable)
# PB_SERPER_KEY=...   # serper.dev (Google)
# PB_BRAVE_KEY=...    # Brave Search API
# PB_TAVILY_KEY=...   # Tavily
